[Unit]
Description=Theater stream + record control app
After=network-online.target mediamtx.service
Wants=mediamtx.service

[Service]
Type=simple
WorkingDirectory=/opt/theater-app
Environment=THEATER_CONFIG=/etc/theater-app/config.yaml
ExecStart=/opt/theater-app/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
